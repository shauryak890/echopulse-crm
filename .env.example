# Copy this file to .env and fill in your own values.
# .env is gitignored. Never commit real credentials.

# --- Supabase (Project Settings > API) ---
#   VITE_SUPABASE_URL       = "Project URL"
#   VITE_SUPABASE_ANON_KEY  = "anon / public" key (safe for the browser, NOT the service_role key)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- Groq (AI: profile text/screenshot -> lead) ---
# Get a free key at https://console.groq.com/keys
# NOTE: this key ships in the browser bundle (client-side app), so treat it as
# public. Keep it on the free tier (no billing) so a leak can't run up a bill.
# Without a key, the "From profile (AI)" and Bulk import features are disabled;
# the rest of the app (manual entry, table, CSV import, dashboards) still works.
VITE_GROQ_API_KEY=your-groq-api-key
